{
  "name": "modern-next-stack",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun --filter web dev",
    "dev:api": "bun --filter api start:dev",
    "lint": "biome check .",
    "lint:fix": "biome check --unsafe --fix .",
    "format": "biome format --write .",
    "generate": "turbo run generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "latest",
    "lefthook": "^2.1.10",
    "turbo": "^2.10.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
